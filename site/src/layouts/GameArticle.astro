---
import type { CollectionEntry } from "astro:content";
import { existsSync } from "node:fs";
import { join } from "node:path";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"games">["data"];

const { title, description, game_name, category, play_count, published_at, updated_at, slug } =
  Astro.props;

const pubDateStr = published_at.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updDateStr = updated_at.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// OGP image: use screenshot if available, otherwise default
const screenshotPath = `/screenshots/${slug}.png`;
const screenshotExists = existsSync(join(process.cwd(), "public", "screenshots", `${slug}.png`));
const ogImage = screenshotExists ? screenshotPath : "/og-default.png";

// Related games: same category, excluding current, max 4
// Deterministic sort by play_count (descending) to avoid SSG cache issues
const allGames = await getCollection("games", ({ data }) => !data.draft);
const relatedGames = allGames
  .filter((g) => g.data.slug !== slug && g.data.category === category)
  .sort((a, b) => {
    const parseCount = (s: string) => {
      const n = parseFloat(s);
      if (s.includes("M")) return n * 1_000_000;
      if (s.includes("K")) return n * 1_000;
      return n || 0;
    };
    return parseCount(b.data.play_count) - parseCount(a.data.play_count);
  })
  .slice(0, 4);

// Structured data
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": `https://dapp-portal-guide.com${ogImage}`,
  "datePublished": published_at.toISOString(),
  "dateModified": updated_at.toISOString(),
  "author": { "@type": "Organization", "name": "Dapp Portal攻略ガイド", "url": "https://dapp-portal-guide.com" },
  "publisher": { "@type": "Organization", "name": "Dapp Portal攻略ガイド", "url": "https://dapp-portal-guide.com" },
  "inLanguage": "ja",
  "mainEntityOfPage": `https://dapp-portal-guide.com/games/${slug}/`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://dapp-portal-guide.com/" },
    { "@type": "ListItem", "position": 2, "name": "ゲーム一覧", "item": "https://dapp-portal-guide.com/games/" },
    { "@type": "ListItem", "position": 3, "name": game_name },
  ],
};
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} image={ogImage} isArticle={true} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .article-container {
        display: flex;
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
        padding: 1em;
      }
      .prose {
        flex: 1;
        max-width: 720px;
        color: rgb(var(--gray-dark));
      }
      .sidebar {
        width: 300px;
        flex-shrink: 0;
      }
      .breadcrumb {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0.8em 1em 0;
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .breadcrumb a {
        color: rgb(var(--gray));
      }
      .game-meta {
        margin-bottom: 1.5em;
        padding: 1em;
        background: rgb(var(--gray-light));
        border-radius: 8px;
      }
      .game-meta .category-badge {
        display: inline-block;
        padding: 0.2em 0.8em;
        background: rgb(var(--accent-dark), 0.1);
        color: var(--accent);
        border-radius: 4px;
        font-size: 0.85em;
        font-weight: 700;
      }
      .game-meta .play-count {
        font-size: 1.1em;
        font-weight: 700;
        margin: 0.5em 0;
      }
      .game-meta .dates {
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .title h1 {
        margin: 0 0 0.5em 0;
        line-height: 1.3;
      }
      .sidebar-card {
        padding: 1.2em;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        color: white;
        margin-bottom: 1.5em;
      }
      .sidebar-card h3 {
        margin: 0 0 0.5em 0;
        font-size: 1.1em;
      }
      .sidebar-card p {
        margin: 0 0 1em 0;
        font-size: 0.9em;
        opacity: 0.9;
      }
      .sidebar-card a {
        display: inline-block;
        padding: 0.6em 1.2em;
        background: white;
        color: #764ba2;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9em;
      }
      .sidebar-card a:hover {
        opacity: 0.9;
      }
      .related-games {
        margin-top: 3em;
        padding-top: 2em;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .related-games h2 {
        font-size: 1.3em;
        margin: 0 0 1em 0;
      }
      .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .related-grid li {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 8px;
        transition: box-shadow 0.2s;
      }
      .related-grid li:hover {
        box-shadow: var(--box-shadow);
      }
      .related-grid a {
        display: block;
        padding: 1em;
        text-decoration: none;
        color: inherit;
      }
      .related-grid .r-category {
        font-size: 0.75em;
        color: rgb(var(--gray));
        font-weight: 700;
      }
      .related-grid .r-name {
        font-size: 1em;
        font-weight: 700;
        margin: 0.2em 0;
      }
      .related-grid .r-meta {
        font-size: 0.8em;
        color: rgb(var(--gray));
      }
      .pr-notice {
        font-size: 0.8em;
        color: rgb(var(--gray));
        background: rgba(var(--gray-light), 0.5);
        padding: 0.4em 0.8em;
        border-radius: 4px;
        margin-bottom: 1.5em;
      }
      .disclaimer {
        margin-top: 2em;
        padding: 1em;
        background: rgba(var(--gray-light), 0.3);
        border-radius: 8px;
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .disclaimer p {
        margin: 0.3em 0;
      }
      @media (max-width: 900px) {
        .article-container {
          flex-direction: column;
        }
        .sidebar {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">ホーム</a> &gt; <a href="/games/">ゲーム一覧</a> &gt; {game_name}
    </nav>
    <main>
      <article>
        <div class="article-container">
          <div class="prose">
            <div class="title">
              <h1>{title}</h1>
            </div>
            <div class="game-meta">
              <span class="category-badge">{category}</span>
              <div class="play-count">{play_count}人がプレイ中</div>
              <div class="dates">
                公開: {pubDateStr}
                {
                  updDateStr !== pubDateStr && (
                    <span>｜更新: {updDateStr}</span>
                  )
                }
              </div>
            </div>
            <p class="pr-notice">※当サイトの記事にはアフィリエイトリンクが含まれます。</p>
            <slot />

            <aside class="disclaimer">
              <p>※本記事の情報は執筆時点のものです。最新の情報は公式サイトをご確認ください。</p>
              <p>※暗号資産の取引にはリスクが伴います。投資は自己責任でお願いします。</p>
            </aside>

            {relatedGames.length > 0 && (
              <section class="related-games">
                <h2>同じカテゴリのおすすめゲーム</h2>
                <ul class="related-grid">
                  {relatedGames.map((g) => (
                    <li>
                      <a href={`/games/${g.data.slug}/`}>
                        <span class="r-category">{g.data.category}</span>
                        <div class="r-name">{g.data.game_name}</div>
                        <span class="r-meta">{g.data.play_count}人プレイ中</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )}
          </div>
          <aside class="sidebar">
            <div class="sidebar-card">
              <h3>KAIAを日本円に換金する方法</h3>
              <p>ゲームで稼いだKAIAトークンを日本円に換金する手順を解説</p>
              <a href="/guide/how-to-cash-out/">換金ガイドを見る</a>
            </div>
            <div class="sidebar-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
              <h3>LINE Dapp Portalとは？</h3>
              <p>LINE上で遊べるWeb3ゲームプラットフォームを初心者向けに解説</p>
              <a href="/guide/what-is-dapp-portal/" style="color: #f5576c;">詳しく見る</a>
            </div>
          </aside>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
