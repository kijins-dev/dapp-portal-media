---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"games">["data"];

const { title, description, game_name, category, play_count, published_at, updated_at } =
  Astro.props;

const pubDateStr = published_at.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updDateStr = updated_at.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .article-container {
        display: flex;
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
        padding: 1em;
      }
      .prose {
        flex: 1;
        max-width: 720px;
        color: rgb(var(--gray-dark));
      }
      .sidebar {
        width: 300px;
        flex-shrink: 0;
      }
      .game-meta {
        margin-bottom: 1.5em;
        padding: 1em;
        background: rgb(var(--gray-light));
        border-radius: 8px;
      }
      .game-meta .category-badge {
        display: inline-block;
        padding: 0.2em 0.8em;
        background: rgb(var(--accent-dark), 0.1);
        color: var(--accent);
        border-radius: 4px;
        font-size: 0.85em;
        font-weight: 700;
      }
      .game-meta .play-count {
        font-size: 1.1em;
        font-weight: 700;
        margin: 0.5em 0;
      }
      .game-meta .dates {
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .title h1 {
        margin: 0 0 0.5em 0;
        line-height: 1.3;
      }
      .sidebar-card {
        padding: 1.2em;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        color: white;
        margin-bottom: 1.5em;
      }
      .sidebar-card h3 {
        margin: 0 0 0.5em 0;
        font-size: 1.1em;
      }
      .sidebar-card p {
        margin: 0 0 1em 0;
        font-size: 0.9em;
        opacity: 0.9;
      }
      .sidebar-card a {
        display: inline-block;
        padding: 0.6em 1.2em;
        background: white;
        color: #764ba2;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9em;
      }
      .sidebar-card a:hover {
        opacity: 0.9;
      }
      @media (max-width: 900px) {
        .article-container {
          flex-direction: column;
        }
        .sidebar {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="article-container">
          <div class="prose">
            <div class="title">
              <h1>{title}</h1>
            </div>
            <div class="game-meta">
              <span class="category-badge">{category}</span>
              <div class="play-count">{play_count}人がプレイ中</div>
              <div class="dates">
                公開: {pubDateStr}
                {
                  updDateStr !== pubDateStr && (
                    <span>｜更新: {updDateStr}</span>
                  )
                }
              </div>
            </div>
            <slot />
          </div>
          <aside class="sidebar">
            <div class="sidebar-card">
              <h3>KAIAを日本円に換金する方法</h3>
              <p>ゲームで稼いだKAIAトークンを日本円に換金する手順を解説</p>
              <a href="/guide/how-to-cash-out/">換金ガイドを見る</a>
            </div>
            <div class="sidebar-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
              <h3>LINE Dapp Portalとは？</h3>
              <p>LINE上で遊べるWeb3ゲームプラットフォームを初心者向けに解説</p>
              <a href="/guide/what-is-dapp-portal/" style="color: #f5576c;">詳しく見る</a>
            </div>
          </aside>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
