---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const parsePlayCount = (s: string) => {
  const n = parseFloat(s);
  if (s.includes("M")) return n * 1_000_000;
  if (s.includes("K")) return n * 1_000;
  return n || 0;
};

const games = (await getCollection("games", ({ data }) => !data.draft)).sort(
  (a, b) => parsePlayCount(b.data.play_count) - parsePlayCount(a.data.play_count)
);

const categories = [...new Set(games.map((g) => g.data.category))].sort();
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`全ゲーム一覧 | ${SITE_TITLE}`}
      description={`LINE Dapp Portal（Mini Dapp）の全${games.length}ゲーム攻略記事一覧。カテゴリ別に検索・フィルター可能。`}
    />
    <style>
      main {
        width: 960px;
        max-width: calc(100% - 2em);
        margin: 0 auto;
        padding: 1em;
      }
      h1 { margin-bottom: 0.5em; }
      .subtitle {
        color: rgb(var(--gray));
        font-size: 0.9em;
        margin-bottom: 1.5em;
      }
      .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.5em;
      }
      .filter-btn {
        padding: 0.4em 1em;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 20px;
        background: white;
        color: rgb(var(--gray));
        font-size: 0.85em;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
      }
      .filter-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
      }
      .filter-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }
      .game-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .game-card {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 12px;
        overflow: hidden;
        transition: box-shadow 0.2s;
      }
      .game-card:hover {
        box-shadow: var(--box-shadow);
      }
      .game-card a {
        display: block;
        padding: 1.2em;
        text-decoration: none;
        color: inherit;
      }
      .game-card .category {
        display: inline-block;
        padding: 0.15em 0.5em;
        background: rgb(var(--gray-light));
        border-radius: 3px;
        font-size: 0.75em;
        font-weight: 700;
        color: rgb(var(--gray));
        margin-bottom: 0.5em;
      }
      .game-card h3 {
        margin: 0 0 0.3em 0;
        font-size: 1.1em;
        line-height: 1.3;
      }
      .game-card .meta {
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .game-card[hidden] { display: none; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>全ゲーム攻略記事</h1>
      <p class="subtitle">{games.length}タイトルの攻略ガイド（プレイ人数順）</p>

      <div class="filter-bar">
        <button class="filter-btn active" data-category="all">すべて</button>
        {categories.map((cat) => (
          <button class="filter-btn" data-category={cat}>{cat}</button>
        ))}
      </div>

      <ul class="game-grid" id="game-list">
        {
          games.map((game) => (
            <li class="game-card" data-cat={game.data.category}>
              <a href={`/games/${game.data.slug}/`}>
                <span class="category">{game.data.category}</span>
                <h3>{game.data.game_name}</h3>
                <p class="meta">
                  {game.data.play_count}人プレイ中
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />

    <script>
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const cat = btn.getAttribute('data-category');
          document.querySelectorAll('.game-card').forEach(card => {
            if (cat === 'all' || card.getAttribute('data-cat') === cat) {
              card.removeAttribute('hidden');
            } else {
              card.setAttribute('hidden', '');
            }
          });
        });
      });
    </script>
  </body>
</html>
