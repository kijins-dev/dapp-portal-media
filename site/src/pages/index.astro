---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const allGames = await getCollection("games", ({ data }) => !data.draft);
// Sort by play count (most popular first) since most articles share the same publish date
const parsePlayCount = (s: string) => {
  const n = parseFloat(s);
  if (s.includes("M")) return n * 1_000_000;
  if (s.includes("K")) return n * 1_000;
  return n || 0;
};
const latestGames = allGames
  .sort((a, b) => parsePlayCount(b.data.play_count) - parsePlayCount(a.data.play_count))
  .slice(0, 6);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 1em;
      }
      .hero {
        text-align: center;
        padding: 3em 1em;
        margin-bottom: 2em;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        color: white;
      }
      .hero h1 {
        font-size: 2em;
        margin: 0 0 0.5em 0;
      }
      .hero p {
        font-size: 1.1em;
        opacity: 0.9;
        margin: 0;
      }
      h2 {
        margin: 2em 0 1em 0;
      }
      .game-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .game-card {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 12px;
        overflow: hidden;
        transition: box-shadow 0.2s;
      }
      .game-card:hover {
        box-shadow: var(--box-shadow);
      }
      .game-card a {
        display: block;
        padding: 1.2em;
        text-decoration: none;
        color: inherit;
      }
      .game-card .category {
        display: inline-block;
        padding: 0.15em 0.5em;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgb(var(--gray-light));
        border-radius: 3px;
        font-size: 0.75em;
        font-weight: 700;
        color: rgb(var(--gray));
        margin-bottom: 0.5em;
      }
      .game-card h3 {
        margin: 0 0 0.3em 0;
        font-size: 1.1em;
        line-height: 1.3;
      }
      .game-card .meta {
        font-size: 0.85em;
        color: rgb(var(--gray));
      }
      .guides-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 1em;
      }
      .guide-card {
        padding: 1.5em;
        border-radius: 12px;
        color: white;
      }
      .guide-card:first-child {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      }
      .guide-card:last-child {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      }
      .guide-card h3 {
        margin: 0 0 0.5em 0;
      }
      .guide-card p {
        opacity: 0.9;
        margin: 0 0 1em 0;
      }
      .guide-card a {
        color: white;
        font-weight: 700;
      }
      .view-all {
        text-align: center;
        margin: 2em 0;
      }
      .view-all a {
        display: inline-block;
        padding: 0.8em 2em;
        border: 2px solid var(--accent);
        border-radius: 8px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 700;
      }
      @media (max-width: 720px) {
        .guides-section {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>LINE Dapp Portal 全ゲーム攻略</h1>
        <p>Mini Dappの遊び方・攻略のコツ・報酬の稼ぎ方を徹底解説</p>
      </section>

      <h2>人気の攻略記事</h2>
      <ul class="game-grid">
        {
          latestGames.map((game) => (
            <li class="game-card">
              <a href={`/games/${game.data.slug}/`}>
                <span class="category">{game.data.category}</span>
                <h3>{game.data.game_name}</h3>
                <p class="meta">{game.data.play_count}人プレイ中</p>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="view-all">
        <a href="/games/">全ゲーム一覧を見る</a>
      </div>

      <h2>ガイド</h2>
      <div class="guides-section">
        <div class="guide-card">
          <h3>KAIAの換金方法</h3>
          <p>ゲームで稼いだKAIAトークンを日本円に換金する方法を解説</p>
          <a href="/guide/how-to-cash-out/">詳しく見る →</a>
        </div>
        <div class="guide-card">
          <h3>LINE Dapp Portalとは？</h3>
          <p>LINEのWeb3ゲームプラットフォームを初心者向けに解説</p>
          <a href="/guide/what-is-dapp-portal/">詳しく見る →</a>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
