---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides", ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: guide,
  }));
}
type Props = CollectionEntry<"guides">;

const guide = Astro.props;
const { Content } = await render(guide);

const pubDateStr = guide.data.published_at.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updDateStr = guide.data.updated_at.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://dapp-portal-guide.com/" },
    { "@type": "ListItem", "position": 2, "name": guide.data.title },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": guide.data.title,
  "description": guide.data.description,
  "datePublished": guide.data.published_at.toISOString(),
  "dateModified": guide.data.updated_at.toISOString(),
  "author": { "@type": "Organization", "name": "Dapp Portal攻略ガイド", "url": "https://dapp-portal-guide.com" },
  "publisher": { "@type": "Organization", "name": "Dapp Portal攻略ガイド", "url": "https://dapp-portal-guide.com" },
  "inLanguage": "ja",
};
---

<html lang="ja">
  <head>
    <BaseHead title={guide.data.title} description={guide.data.description} isArticle={true} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <style>
      main {
        max-width: 780px;
        margin: 0 auto;
        padding: 2em 1em;
        color: rgb(var(--gray-dark));
        line-height: 1.8;
      }
      .breadcrumb {
        font-size: 0.85em;
        color: rgb(var(--gray));
        margin-bottom: 1em;
      }
      .breadcrumb a {
        color: rgb(var(--gray));
      }
      h1 {
        font-size: 1.8em;
        line-height: 1.3;
        margin-bottom: 0.5em;
      }
      .dates {
        font-size: 0.85em;
        color: rgb(var(--gray));
        margin-bottom: 2em;
      }
      .prose :global(h2) {
        font-size: 1.3em;
        margin-top: 2em;
        border-bottom: 1px solid rgb(var(--gray-light));
        padding-bottom: 0.3em;
      }
      .prose :global(h3) {
        font-size: 1.1em;
        margin-top: 1.5em;
      }
      .prose :global(ul), .prose :global(ol) {
        padding-left: 1.5em;
      }
      .prose :global(li) {
        margin: 0.3em 0;
      }
      .prose :global(a) {
        color: var(--accent);
      }
      .prose :global(strong) {
        color: rgb(var(--gray-dark));
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/">ホーム</a> &gt; {guide.data.title}
      </nav>
      <h1>{guide.data.title}</h1>
      <div class="dates">
        公開: {pubDateStr}
        {updDateStr !== pubDateStr && <span>｜更新: {updDateStr}</span>}
      </div>
      <div class="prose">
        <Content />
      </div>
    </main>
    <Footer />
  </body>
</html>
